{
  "manifest_version": 2,
  "name": "Lazy Bookmark Opener",
  "version": "1.2",
  "description": "Open bookmark folders as suspended placeholder tabs",
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png"
  },
  "permissions": [
    "bookmarks",
    "tabs",
    "contextMenus"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "lazy-bookmarks@example.com",
      "data_collection_permissions": {
        "required": [ "none" ]
      }
    }
  }
}